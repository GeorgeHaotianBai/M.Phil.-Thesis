\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Majority reaction functions and strategic complements/substitutes.} The figure plots the equilibrium response $E_M^*(S_k,E_m)$ from \autoref {eq:EM_star} as a function of $E_m$, for two technology levels: a high-capacity Hawk ($S_A$) and a low-capacity Dove ($S_B$). Each curve is single-peaked at $E_m^{\mathrm  {peak}}(S_k)$ from Lemma \autoref {lem:reaction_invertedU}. For $E_m<E_m^{\mathrm  {peak}}(S_k)$, enforcement and opposition mobilization are strategic complements ($\partial E_M^*/\partial E_m>0$); for $E_m>E_m^{\mathrm  {peak}}(S_k)$ they are strategic substitutes ($\partial E_M^*/\partial E_m<0$). The arrow illustrates how a more provocative symbolic policy $d$ raises $E_m(d)$ and thereby moves the economy along the high-$S_k$ reaction curve, activating Majority enforcement. Illustration uses $(N_M,\Lambda ,S_A,S_B)=(100,1,1.0,0.4)$.}}{10}{figure.caption.2}\protected@file@percent }
\newlabel{fig:reaction_functions}{{2}{10}{\textbf {Majority reaction functions and strategic complements/substitutes.} The figure plots the equilibrium response $E_M^*(S_k,E_m)$ from \autoref {eq:EM_star} as a function of $E_m$, for two technology levels: a high-capacity Hawk ($S_A$) and a low-capacity Dove ($S_B$). Each curve is single-peaked at $E_m^{\mathrm {peak}}(S_k)$ from Lemma \autoref {lem:reaction_invertedU}. For $E_m<E_m^{\mathrm {peak}}(S_k)$, enforcement and opposition mobilization are strategic complements ($\partial E_M^*/\partial E_m>0$); for $E_m>E_m^{\mathrm {peak}}(S_k)$ they are strategic substitutes ($\partial E_M^*/\partial E_m<0$). The arrow illustrates how a more provocative symbolic policy $d$ raises $E_m(d)$ and thereby moves the economy along the high-$S_k$ reaction curve, activating Majority enforcement. Illustration uses $(N_M,\Lambda ,S_A,S_B)=(100,1,1.0,0.4)$}{figure.caption.2}{}}
\newlabel{fig:reaction_functions@cref}{{[figure][2][]2}{[1][9][]10}{}{}{}}
\citation{barut1998symmetric}
\citation{barut1998symmetric}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Rent dissipation under symbolic policy.} The figure plots $RD(d,S_k)$ from \autoref {eq:RD} against symbolic policy intensity $d$, for two levels of state capacity. By inducing $E_m(d)>0$, symbolic policy creates a contest that wastes real resources through both Minority mobilization and Majority enforcement. Unlike the neutral contest designer studied in standard contest design settings (e.g., \citet  {barut1998symmetric}), the political incumbent is biased: the Hawk may deliberately choose a strictly positive $d$---and hence strictly positive dissipation---because the induced conflict helps expand the Security Premium in the election. Illustration uses $(N_M,\Lambda ,\gamma ,\sigma ,S_A,S_B)=(100,1,5,1,1.0,0.2)$.}}{11}{figure.caption.3}\protected@file@percent }
\newlabel{fig:rent_dissipation}{{3}{11}{\textbf {Rent dissipation under symbolic policy.} The figure plots $RD(d,S_k)$ from \autoref {eq:RD} against symbolic policy intensity $d$, for two levels of state capacity. By inducing $E_m(d)>0$, symbolic policy creates a contest that wastes real resources through both Minority mobilization and Majority enforcement. Unlike the neutral contest designer studied in standard contest design settings (e.g., \citet {barut1998symmetric}), the political incumbent is biased: the Hawk may deliberately choose a strictly positive $d$---and hence strictly positive dissipation---because the induced conflict helps expand the Security Premium in the election. Illustration uses $(N_M,\Lambda ,\gamma ,\sigma ,S_A,S_B)=(100,1,5,1,1.0,0.2)$}{figure.caption.3}{}}
\newlabel{fig:rent_dissipation@cref}{{[figure][3][]3}{[1][11][]11}{}{}{}}
