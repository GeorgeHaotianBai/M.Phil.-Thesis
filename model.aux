\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Majority mobilization as a function of asymmetric technology.} The figure plots the symmetric equilibrium $E_M^*(S_k,E_m)$ implied by \autoref {eq:EM_star} as $S_k$ varies, holding $(N_M,\Lambda ,E_m)=(100,1,5)$ fixed. The plotted range focuses on the increasing branch $S_k\le \overline  {S}(E_m)$ from Corollary \autoref {cor:Sk_threshold}, on which higher state capacity raises the marginal return to individual effort in the contest success function \autoref {eq:CSF} and alleviates the Majority's free-rider problem.}}{8}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:Sk_statics}{{1}{8}{\textbf {Majority mobilization as a function of asymmetric technology.} The figure plots the symmetric equilibrium $E_M^*(S_k,E_m)$ implied by \autoref {eq:EM_star} as $S_k$ varies, holding $(N_M,\Lambda ,E_m)=(100,1,5)$ fixed. The plotted range focuses on the increasing branch $S_k\le \overline {S}(E_m)$ from Corollary \autoref {cor:Sk_threshold}, on which higher state capacity raises the marginal return to individual effort in the contest success function \autoref {eq:CSF} and alleviates the Majority's free-rider problem}{figure.caption.1}{}}
